# ══════════════════════════════════════════════════════════════════
#  Lexora Library — Environment Variables Example
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-with-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://lexora:lexora@localhost:5432/lexora_db

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ─────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Lexora Library <noreply@lexora.com>

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Security (production only) ───────────────────────────────────
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── Business Rules ───────────────────────────────────────────────
MAX_LOANS_PER_USER=5
LOAN_DURATION_DAYS=14
FINE_PER_DAY=0.50
RENEWAL_LIMIT=2

# ── Sentry (production) ──────────────────────────────────────────
SENTRY_DSN=
APP_VERSION=1.0.0

# ── Storage (AWS S3 — production) ────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
